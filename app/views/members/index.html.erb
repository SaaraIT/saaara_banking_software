<div class="d-flex justify-content-between align-items-center mt-3">
  <h5 class="mb-0">Membership Applications</h5>
  <%= link_to "New Membership", new_member_path, class: "btn btn-primary" %>
</div>
<br />

<%= search_form_for @q do |f| %>

 <table class='table table-bordered search-table' >
   <tr>
      <th> <%= f.label :name_cont %>:
       <%= f.search_field :name_cont %> </th>
      <th> <%= f.label :mobile_number_cont %>:
       <%= f.search_field :mobile_number_cont %> </th>
      <th> <%= f.label :aadhaar_number_cont %>:
       <%= f.search_field :aadhaar_number_cont %> </th>
      <th rowspan="2">  <%= f.submit "Search", class: 'btn btn-secondary btn-sm' %> </th>
   </tr>
 
<% end %>

<table class='table table-bordered list-table'>
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Mobile Number</th>
      <th>Aadhaar Number</th>
      
      
 
      <th>Number of Shares</th>
 
      <th>Created At</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @members.each do |member| %>
      <tr>
        <td><%= member.id %></td>
        <td><%= member.name %></td>
        <td><%= member.mobile_number %></td>
        <td><%= member.aadhaar_number %></td>
 
       
 
        <td><%= member.memberships.last.number_of_shares %></td>
   
        <td><%= member.cooperative_branch.try(:name) %></td>
        <td>
          <%= link_to "Print", member_path(member, format: :pdf), target: "_blank" , class: 'btn btn-info  btn-sm ' %>
          <% if current_user.super_admin? || current_user.section_head? || current_user.manager? %>
            <%= link_to "Edit", edit_member_path(member), class: 'btn btn-sm btn-warning' %>
          <% elsif current_user.staff? && member.cooperative_branch_id == current_user.cooperative_branch_id %>
            <% if EditRequest.has_approved_request?('Member', member.id, current_user.id) %>
              <%= link_to "Edit", edit_member_path(member), class: 'btn btn-sm btn-warning' %>
            <% end %>
          <% end %>
          <%= link_to "Show", member_path(member), class: 'btn btn-sm btn-secondary' %>
          <%= link_to "Accounts", member_accounts_path(member), class: "btn btn-sm btn-success" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
