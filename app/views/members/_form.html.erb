<script>
  document.addEventListener("turbo:load", function() {
    const sameAddress = document.getElementById("same_address");
    const sameAddress1 = document.getElementById("same_address1");

    if (sameAddress) {
      sameAddress.addEventListener("change", function() {
        const aBuilding = document.getElementById("member_address_a_building");
        const aVillage = document.getElementById("member_address_a_village");
        const aDistrict = document.getElementById("member_address_a_district");
        const aPincode = document.getElementById("member_address_a_pincode");

        const bBuilding = document.getElementById("member_address_b_building");
        const bVillage = document.getElementById("member_address_b_village");
        const bDistrict = document.getElementById("member_address_b_district");
        const bPincode = document.getElementById("member_address_b_pincode");

        if (this.checked) {
          bBuilding.value = aBuilding.value;
          bVillage.value = aVillage.value;
          bDistrict.value = aDistrict.value;
          bPincode.value = aPincode.value;
        } else {
          bBuilding.value = "";
          bVillage.value = "";
          bDistrict.value = "";
          bPincode.value = "";
        }
      });
    }

    if (sameAddress1) {
      sameAddress1.addEventListener("change", function() {
        const aBuilding = document.getElementById("member_address_a_building");
        const aVillage = document.getElementById("member_address_a_village");
        const aDistrict = document.getElementById("member_address_a_district");
        const aPincode = document.getElementById("member_address_a_pincode");

        const nomineeAddress = document.getElementById("member_memberships_attributes_0_nominee_address");

        if (this.checked) {
          nomineeAddress.value = `${aBuilding.value}, ${aVillage.value}, ${aDistrict.value}, ${aPincode.value}`;
        } else {
          nomineeAddress.value = "";
        }
      });
    }
  });
</script>

