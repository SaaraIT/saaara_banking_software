<div class="container-fluid">
  <h1 class="h2 mb-4">Edit Term Deposit Type</h1>
  <%= link_to "Back to Term Deposit Types", admin_term_deposit_types_path, class: "btn btn-outline-secondary mb-3" %>
  <div class="row">
    <div class="col-md-6">
      <div class="card">
        <div class="card-body">
          <%= form_with model: @term_deposit_type, url: admin_update_term_deposit_type_path(@term_deposit_type), method: :patch, local: true do |f| %>
            <div class="mb-3">
              <label class="form-label">Type Name</label>
              <%= f.text_field :name, class: "form-control" %>
            </div>
            <div class="mb-3 form-check">
              <%= f.check_box :active, class: "form-check-input" %>
              <label class="form-check-label">Active</label>
            </div>
            <%= f.submit "Update Term Deposit Type", class: "btn btn-success w-100" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
