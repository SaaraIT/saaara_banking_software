<div class="container-fluid">
  <h1 class="h2 mb-4">Add New Type of Term Deposit</h1>
  <%= link_to "Back to Term Deposit Types", admin_term_deposit_types_path, class: "btn btn-outline-secondary mb-3" %>
  <div class="row">
    <div class="col-md-6">
      <div class="card">
        <div class="card-body">
          <%= form_with model: @term_deposit_type, url: admin_create_term_deposit_type_path, local: true do |f| %>
            <% if @term_deposit_type.errors.any? %>
              <div class="alert alert-danger">
                <% @term_deposit_type.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
              </div>
            <% end %>
            <div class="mb-3">
              <label class="form-label">Type Name</label>
              <%= f.text_field :name, class: "form-control", placeholder: "e.g., FD (Fixed Deposit)" %>
            </div>
            <div class="mb-3 form-check">
              <%= f.check_box :active, class: "form-check-input", checked: true %>
              <label class="form-check-label">Active</label>
            </div>
            <%= f.submit "Create Term Deposit Type", class: "btn btn-success w-100" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
