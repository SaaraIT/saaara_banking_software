<style>
  .acc-section { border: 1px solid #aaa; padding: 12px 15px; margin-bottom: 20px; }
  .acc-section h5 { text-decoration: underline; text-align: center; margin-bottom: 15px; font-weight: bold; }
  .acc-table { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
  .acc-table th, .acc-table td { border: 1px solid #aaa; padding: 6px 8px; font-size: 14px; }
  .acc-table th { background: #f5f5f5; font-weight: 600; }
  .acc-input { border: none; border-bottom: 1px solid #333; outline: none; width: 100%; background: transparent; padding: 2px 4px; }
  .header-table { width: 100%; margin-bottom: 10px; }
  .form-check-inline { margin-right: 15px; }
</style>

<% url = action == :new ? member_accounts_path(@member) : member_account_path(@member, @account) %>
<% method = action == :new ? :post : :patch %>

<%= form_with model: [@member, account], url: url, method: method, local: true do |f| %>
  <% if account.errors.any? %>
    <div class="alert alert-danger">
      <% account.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </div>
  <% end %>

  <%# ── HEADER ── %>
  <table class="header-table">
    <tr>
      <td style="width:100px"><%= image_tag "logo.png", style: "width:120px" %></td>
      <td style="text-align:center">
        <h4 style="margin:0; font-size:22px;">MATHRUBHOOMI SOUHARDA SAHAKARI SANGHA LTD</h4>
        <p style="margin:2px 0; font-size:13px">REG.NO.526/2005-06</p>
        <p style="margin:2px 0; font-size:12px">Regd.Office: "Mathrudhama" Gurupura-Kaikamba Kinnikambala Mangalore D.K.-574151 Ph: 9606912823</p>
        <h5 style="margin-top:6px; font-size:18px;">APPLICATION FORM FOR ACCOUNT OPENING</h5>
      </td>
    </tr>
  </table>

  <div style="display:flex; justify-content:space-between; margin-bottom:10px">
    <div>
      Date: <%= f.date_field :date, class: "acc-input", style: "width:160px", value: Date.today %>
    </div>
    <div>
      Account Number: <%= f.text_field :account_number, class: "acc-input", style: "width:180px" %>
    </div>
    <div>
      Branch: <%= f.text_field :branch, class: "acc-input", style: "width:160px", value: Current.branch.try(:name) %>
    </div>
  </div>

  <%# ── MEMBER NOs ── %>
  <div class="acc-section">
    <table class="acc-table">
      <tr>
        <th></th><th>1st Applicant</th><th>2nd Applicant</th><th>3rd Applicant</th>
      </tr>

<tr>
        <td><strong>Member No (From Membership Form)</strong></td>
        <td><strong><%= @member.member_no.present? ? "#{@member.name} (#{@member.member_no})" : @member.name %></strong></td>
        <td>
          <div class="member-search-wrap">
            <input type="text" id="search_app2" class="acc-input" placeholder="Type name or member no..." autocomplete="off">
            <div id="dropdown_app2" class="member-dropdown" style="display:none"></div>
          </div>
          
          <input type="hidden" id="app2_member_id" name="app2_member_id">
        </td>
        <td>
          <div class="member-search-wrap">
            <input type="text" id="search_app3" class="acc-input" placeholder="Type name or member no..." autocomplete="off">
            <div id="dropdown_app3" class="member-dropdown" style="display:none"></div>
          </div>
          
          <input type="hidden" id="app3_member_id" name="app3_member_id">
        </td>
      </tr>



    </table>
    <p>I/We request you to open an account with you for which I/We initially
      ₹ <%= f.number_field :initial_deposit, class: "acc-input", style: "width:120px", step: "0.01" %>
      (in words) <%= f.text_field :initial_deposit_words, class: "acc-input", style: "width:500px" %>
    </p>

    <%# Account Type %>
    <strong>Account Type:</strong>&nbsp;
    <% [["Members Savings Account","savings"],["Current Account","current"],["Other Account","other"]].each do |label, val| %>
      <label class="form-check-inline">
        <%= f.radio_button :account_type, val %>  <%= label %>
      </label>
    <% end %>
  </div>

  <%# ── TERM DEPOSIT ── %>
  <div class="acc-section">
    <h5>Term Deposit</h5>
    <table class="acc-table">
      <tr>
        <th style="width:30%">Type of Term Deposit</th>
        <td><%= f.select :term_deposit_type, TermDepositType.active.order(:name).pluck(:name), { prompt: "Select Type" }, class: "form-select form-select-sm" %></td>
      </tr>
      <tr>
        <td>Deposit Amount (₹)</td>
        <td><%= f.text_field :term_deposit_amount, class: "acc-input" %></td>
      </tr>
      <tr>
        <td>Deposit Period</td>
        <td>
          From: <%= f.date_field :term_deposit_period_d, class: "acc-input", style: "width:180px", id: "td_from" %>
          &nbsp;&nbsp;
          To: <%= f.date_field :term_deposit_period_m, class: "acc-input", style: "width:180px", id: "td_to" %>
          &nbsp;&nbsp;
          <span id="td_duration" style="font-size:13px; color:#1a6b3c; font-weight:600;"></span>
        </td>
      </tr>
      <tr>
        <td>Interest Payable</td>
        <td>
          <%= f.select :term_interest_payable, ["Monthly","Quarterly","On Maturity"], { prompt: "Select" }, class: "form-select form-select-sm" %>
        </td>
      </tr>
      <tr>
        <td>For Interest - Credit to A/c No.</td>
        <td><%= f.text_field :term_interest_credit_ac, class: "acc-input" %></td>
      </tr>
      <tr>
        <td>Rate of Interest (%)</td>
        <td><%= f.number_field :term_interest_rate, class: "acc-input", style: "width:120px", step: "0.01", placeholder: "e.g. 8.5" %></td>
      </tr>
      <tr>
        <td>Payment</td>
        <td>
          <%= f.select :term_interest_payment, ["Issue DD/PO","By Cash","By Transfer"], { prompt: "Select" }, class: "form-select form-select-sm" %>
        </td>
      </tr>
    </table>
  </div>

  <%# ── RECURRING DEPOSIT ── %>
  <div class="acc-section">
    <h5>Recurring Deposit</h5>
    <table class="acc-table">
      <tr>
        <th style="width:30%">RD Amount (₹)</th>
        <td><%= f.text_field :rd_deposit_amount, class: "acc-input" %></td>
      </tr>
      <tr>
        <td>Deposit Period</td>
        <td>
          From: <%= f.date_field :rd_deposit_period_m, class: "acc-input", style: "width:180px", id: "rd_from" %>
          &nbsp;&nbsp;
          To: <%= f.date_field :rd_deposit_period_y, class: "acc-input", style: "width:180px", id: "rd_to" %>
          &nbsp;&nbsp;
          <span id="rd_duration" style="font-size:13px; color:#1a6b3c; font-weight:600;"></span>
        </td>
      </tr>
      <tr>
        <td>Standing Instruction</td>
        <td>
          Debit SB A/c No. <%= f.text_field :rd_sb_ac_no, class: "acc-input", style: "width:160px" %>
          &nbsp;&nbsp;
          Credit RD A/c No. <%= f.text_field :rd_credit_ac_no, class: "acc-input", style: "width:160px" %>
        </td>
      </tr>
      <tr>
        <td>Rate of Interest (%)</td>
        <td><%= f.number_field :rd_interest_rate, class: "acc-input", style: "width:120px", step: "0.01", placeholder: "e.g. 7.0" %></td>
      </tr>
      <tr>
        <td>Payment</td>
        <td>
          <%= f.select :term_deposit_period_y, ["Issue DD/PO","By Cash","By Transfer"], { prompt: "Select" }, class: "form-select form-select-sm" %>
        </td>
      </tr>
    </table>
  </div>

  <%# ── CUSTOMER TYPE ── %>
  <div class="acc-section">
    <h5>Customer's Type</h5>
    <%= f.select :customer_type, ["Individual","Individual-Staff","Minor","Individual Senior Citizen","HUF","Institution","Private Ltd.","Public Ltd","Govt. Organisation","Co-Op Society","Partnership"], { prompt: "Select Customer Type" }, class: "form-select" %>
  </div>

  <%# ── APPLICANT DETAILS ── %>
  <div class="acc-section">
    <h5>Name of Customer's</h5>
    <table class="acc-table">
      <tr><th></th><th>Name</th><th>Date of Birth</th><th>Aadhaar</th><th>Sex</th></tr>
      <tr>
        <td><strong>1st Applicant</strong></td>
        <td><%= f.text_field :app1_name, class: "acc-input", value: @member.name %></td>
        <td><%= f.date_field :app1_dob, class: "acc-input" %></td>
        <td><%= f.text_field :app1_aadhaar, class: "acc-input", value: @member.aadhaar_number %></td>
        <td><%= f.select :app1_sex, ["Male","Female","Other"], { prompt: "Select" }, class: "form-select form-select-sm" %></td>
      </tr>
      <tr>
        <td><strong>2nd Applicant</strong></td>
        <td><%= f.text_field :app2_name, class: "acc-input", id: "app2_name" %></td>
        <td><%= f.date_field :app2_dob, class: "acc-input", id: "app2_dob" %></td>
        <td><%= f.text_field :app2_aadhaar, class: "acc-input", id: "app2_aadhaar" %></td>
        <td><%= f.select :app2_sex, ["Male","Female","Other"], { prompt: "Select" }, class: "form-select form-select-sm", id: "app2_sex" %></td>
      </tr>
      <tr>
        <td><strong>3rd Applicant</strong></td>
        <td><%= f.text_field :app3_name, class: "acc-input", id: "app3_name" %></td>
        <td><%= f.date_field :app3_dob, class: "acc-input", id: "app3_dob" %></td>
        <td><%= f.text_field :app3_aadhaar, class: "acc-input", id: "app3_aadhaar" %></td>
        <td><%= f.select :app3_sex, ["Male","Female","Other"], { prompt: "Select" }, class: "form-select form-select-sm", id: "app3_sex" %></td>
      </tr>
    </table>

    <h5 style="margin-top:15px">Father/Husband/Guardian Name</h5>
    <table class="acc-table">
      <tr><th></th><th>Name</th><th>Relationship</th></tr>
      <tr>
        <td><strong>1st Applicant</strong></td>
        <td><%= f.text_field :app1_father_husband, class: "acc-input", value: @member.father_or_husband_name %></td>
        <td><%= f.text_field :app1_relationship, class: "acc-input" %></td>
      </tr>
      <tr>
        <td><strong>2nd Applicant</strong></td>
        <td><%= f.text_field :app2_father_husband, class: "acc-input", id: "app2_father_husband" %></td>
        <td><%= f.text_field :app2_relationship, class: "acc-input", id: "app2_relationship" %></td>
      </tr>
      <tr>
        <td><strong>3rd Applicant</strong></td>
        <td><%= f.text_field :app3_father_husband, class: "acc-input", id: "app3_father_husband" %></td>
        <td><%= f.text_field :app3_relationship, class: "acc-input", id: "app3_relationship" %></td>
      </tr>
    </table>
  </div>

  <%# ── ADDRESS ── %>
  <div class="acc-section">
    <h5>Address For Communication</h5>

    <% [["1st", "app1"], ["2nd", "app2"], ["3rd", "app3"]].each do |label, prefix| %>
      <% m = prefix == "app1" ? @member : nil %>
      <strong><%= label %> Applicant</strong>
      <table class="acc-table" style="margin-bottom:10px">
        <tr>
          <th colspan="2">Permanent Address</th>
          <th colspan="2">Present Address</th>
        </tr>
        <tr>
          <td>D.No/House Name</td>
          <td><%= f.text_field :"#{prefix}_perm_house", class: "acc-input", id: "#{prefix}_perm_house", value: m&.address_a_building %></td>
          <td>D.No/House Name</td>
          <td><%= f.text_field :"#{prefix}_pres_house", class: "acc-input", id: "#{prefix}_pres_house", value: m&.address_b_building %></td>
        </tr>
        <tr>
          <td>Place, Post & Village</td>
          <td><%= f.text_field :"#{prefix}_perm_village", class: "acc-input", id: "#{prefix}_perm_village", value: m&.address_a_village %></td>
          <td>Place, Post & Village</td>
          <td><%= f.text_field :"#{prefix}_pres_village", class: "acc-input", id: "#{prefix}_pres_village", value: m&.address_b_village %></td>
        </tr>
        <tr>
          <td>Taluk, District</td>
          <td><%= f.text_field :"#{prefix}_perm_district", class: "acc-input", id: "#{prefix}_perm_district", value: m&.address_a_district %></td>
          <td>Taluk, District</td>
          <td><%= f.text_field :"#{prefix}_pres_district", class: "acc-input", id: "#{prefix}_pres_district", value: m&.address_b_district %></td>
        </tr>
        <tr>
          <td>PIN</td>
          <td><%= f.text_field :"#{prefix}_perm_pin", class: "acc-input", id: "#{prefix}_perm_pin", value: m&.address_a_pincode %></td>
          <td>MOBILE</td>
          <td><%= f.text_field :"#{prefix}_pres_mobile", class: "acc-input", id: "#{prefix}_pres_mobile", value: m&.mobile_number %></td>
        </tr>
      </table>
    <% end %>
  </div>

  <%# ── APPLICANT PHOTOS & SIGNATURES ── %>
  <div class="acc-section">
    <h5>Applicant Photo & Specimen Signature</h5>
    <table class="acc-table" style="width:100%">
      <tr>
        <% ["1st Applicant","2nd Applicant","3rd Applicant"].each do |applicant| %>
        <td style="width:33%; text-align:center; padding:15px; border:1px solid #ccc;">
          <p style="font-weight:bold;"><%= applicant %></p>
          <div style="width:160px; height:200px; border:2px dashed #999; margin:0 auto 10px auto; display:flex; align-items:center; justify-content:center; background:#f9f9f9;">
            <span style="color:#aaa; font-size:12px;">Passport Photo</span>
          </div>
          <div style="width:160px; height:80px; border-bottom:2px solid #333; margin:0 auto; display:flex; align-items:flex-end; justify-content:center;">
            <span style="color:#aaa; font-size:11px;">Signature</span>
          </div>
        </td>
        <% end %>
      </tr>
    </table>
  </div>

  <%# ── MODE OF OPERATION ── %>
  <div class="acc-section">
    <h5>Mode of Operation</h5>
    <%= f.select :mode_of_operation, ["Self Only","Either OR Survivor","Former OR Survivor","Any one OR Survivor","Jointly","Others"], { prompt: "Select Mode" }, class: "form-select" %>
  </div>

<%# ── Nominee ── %>
<div class="acc-section">
  <h5>Nominee Details</h5>
  <table class="acc-table" style="width:100%; font-size:13px;">
    <tr>
      <td style="width:35%;"><strong>Name of the Nominee &amp; Address:<span style="color:red">*</span></strong></td>
      <td>
        <%= f.text_field :nominee_name, class: "acc-input", placeholder: "Nominee name" %>
        <%= f.text_area :nominee_address, class: "acc-input", rows: 2, style: "margin-top:2px; width:100%; padding:4px;" %>
      </td>
    </tr>
    <tr>
      <td><strong>And Relationship with Applicant:</strong></td>
      <td>
        <%= f.select :nominee_relationship, ["Select Relationship", "Father", "Mother", "Spouse", "Son", "Daughter", "Brother", "Sister", "Other"], {}, class: "acc-input" %>
      </td>
    </tr>
    <tr>
      <td><strong>with Mobile No:<span style="color:red">*</span></strong></td>
      <td><%= f.text_field :nominee_mobile, class: "acc-input", placeholder: "Mobile number" %></td>
    </tr>
  </table>
</div>

  <%# ── KYC ── %>
  <div class="acc-section">
    <h5>KYC Identification Documents To be Submitted By Applicants</h5>
    <p style="font-size:13px;">(Any one document from each of the following two lists subject to Sahakari's Satisfaction)</p>
    <table class="acc-table table table-bordered" style="width:100%; font-size:13px;">
      <tr>
        <th style="width:5%">#</th>
        <th style="width:45%">LIST 1 - Latest Photo Identification Documents</th>
        <th style="width:5%">#</th>
        <th style="width:45%">LIST 2 - Latest Documents Showing Address Proof</th>
      </tr>
      <tr><td>1</td><td><label><input type='radio' name='account[kyc_list1]' value='Aadhaar'> Aadhaar</label></td><td>1</td><td><label><input type='radio' name='account[kyc_list2]' value='Passport'> Passport</label></td></tr>
      <tr><td>2</td><td><label><input type='radio' name='account[kyc_list1]' value='Pancard'> Pancard</label></td><td>2</td><td><label><input type='radio' name='account[kyc_list2]' value='Rationcard'> Rationcard</label></td></tr>
      <tr><td>3</td><td><label><input type='radio' name='account[kyc_list1]' value='Voters ID Card'> Voters ID Card</label></td><td>3</td><td><label><input type='radio' name='account[kyc_list2]' value='Telephone Bill'> Telephone Bill</label></td></tr>
      <tr><td>4</td><td><label><input type='radio' name='account[kyc_list1]' value='Driving License'> Driving License</label></td><td>4</td><td><label><input type='radio' name='account[kyc_list2]' value='Letter from employer'> Letter from employer</label></td></tr>
      <tr><td>5</td><td><label><input type='radio' name='account[kyc_list1]' value='Identity card issued by the Govt/Public authority'> Identity card issued by the Govt/Public authority</label></td><td>5</td><td><label><input type='radio' name='account[kyc_list2]' value='Bank account statement with address'> Bank account statement with address</label></td></tr>
      <tr><td>6</td><td><label><input type='radio' name='account[kyc_list1]' value='Letter from Employer'> Letter from Employer</label></td><td>6</td><td><label><input type='radio' name='account[kyc_list2]' value='Electricity Bill'> Electricity Bill</label></td></tr>
      <tr><td>7</td><td></td><td>7</td><td><label><input type='radio' name='account[kyc_list2]' value='Income Tax/Property Tax assessment order/Receipt'> Income Tax/Property Tax assessment order/Receipt</label></td></tr>
      <tr><td></td><td></td><td>8</td><td><label><input type='radio' name='account[kyc_list2]' value='Credit card'> Credit card</label></td></tr>
    </table>
    <div style="margin-top:20px; font-size:13px;">
      <p><strong>Declaration:</strong></p>
      <ul style="list-style:disc; padding-left:20px; line-height:2;">
        <li>I/We hereby declare that the rules governing the deposits account have been read by me/us and that I/We agreed to be bound by the rules and bye laws of the sahakari in force now</li>
        <li>I/We hereby declare that the amount deposited in the account of my/our own</li>
        <li>I/We declare that the account will be operated upon and the balance will be payable to myself/Either or Survivor/Anyone or depositors against joint discharge</li>
        <li>I/We hereby undertake the minimum balance of ₹._____ in the account as and also agree to maintain balance as modified by the Sahakari time to time</li>
        <li>I/We also agree that the Sahakari got every right to close the account for non-maintenance of minimum balance</li>
        <li>I/We do agree to the condition that the rate of interest payable by the sahakari on my/our deposit account shall be subject to the changes in the interest rates made by the Mathrubhoomi Souharda Sahakari Sangha Ltd.</li>
        <li>In the event of my/our seeking pre-closure if term deposit/Recurring deposit/ I/We agree that Sahakari shall apply the rules of Pre-closure term deposit/RD prevailing on the date of my/our request for such pre closure</li>
        <li>I/We that the clause repayable to the either or survivor/any one or more or survivor(s) includes the right to the survivors to apply before the date of maturity for repayment or for credit facility against the security to the deposit. I/We further agreed that any one of us can renew the deposit in the same names</li>
        <li>I/We do agreed that the rate of interest payable by the sahakari on my/our deposit for overdue period if unrenewed on the due date shall be subject to the rules of sahakari prevailing at the time of renewal</li>
        <li>Please send/do not send due date notice to my/our address</li>
        <li>I/We shall be liable to you for any monies owing to you from time to time in case the account is over drawn and/debit balance is caused including your commission interest and other incidental charges.</li>
        <li>In the event of the death or insolvency or withdrawal of any of us the survivor/s shall have full control of any monies standing to my/our credit in our account with you and the survivor/s will have full powers to operate the account/close the account</li>
        <li>For current account(individual only) * at present I/We do not enjoy any credit facility with any sahakari's branch. I/We undertake to inform you as when credit facilities are availed by me/us with other bank(s) branches of your bank</li>
      </ul>
    </div>
    <table class="acc-table" style="width:100%; margin-top:30px;">
      <tr>
        <td style="width:33%; text-align:center; padding:15px; border:1px solid #ccc;">
          <div style="height:80px; border-bottom:2px solid #333; margin-bottom:8px;"></div>
          <p style="font-size:13px; font-weight:bold;">1st Applicant Specimen Signature</p>
        </td>
        <td style="width:33%; text-align:center; padding:15px; border:1px solid #ccc;">
          <div style="height:80px; border-bottom:2px solid #333; margin-bottom:8px;"></div>
          <p style="font-size:13px; font-weight:bold;">2nd Applicant Specimen Signature</p>
        </td>
        <td style="width:33%; text-align:center; padding:15px; border:1px solid #ccc;">
          <div style="height:80px; border-bottom:2px solid #333; margin-bottom:8px;"></div>
          <p style="font-size:13px; font-weight:bold;">3rd Applicant Specimen Signature</p>
        </td>
      </tr>
    </table>
  </div>

  <%# ── MINOR ── %>
  <div class="acc-section">
    <h5>IF Minor Account Holder</h5>
    <div class="row">
      <div class="col-md-4 mb-2">
        <label>Name of Parent/Guardian</label>
        <%= f.text_field :minor_guardian_name, class: "form-control form-control-sm" %>
      </div>
      <div class="col-md-4 mb-2">
        <label>Relationship with Minor</label>
        <%= f.select :minor_guardian_relationship,
          ["Father","Mother","By Court Order"],
          { prompt: "Select" }, class: "form-select form-select-sm" %>
      </div>
    </div>
    <div style="text-align:right; margin-top:15px;">
      <div style="display:inline-block; width:220px; text-align:center; padding:10px;">
        <div style="height:80px; border-bottom:2px solid #000; margin-bottom:8px;"></div>
        <p style="font-size:13px; margin:0;"><strong>Guardian Signature</strong></p>
      </div>
    </div>
  </div>

<%# ── CUSTOMER PROFILE HEADER ── %>
<div class="acc-section" style="border:2px solid #aaa; padding:15px; margin-bottom:0;">
  <table class="header-table">
    <tr>
      <td style="width:100px"><%= image_tag "logo.png", style: "width:120px" %></td>
      <td style="text-align:center">
        <h4 style="margin:0; font-size:22px;">MATHRUBHOOMI SOUHARDA SAHAKARI SANGHA LTD</h4>
        <p style="margin:2px 0; font-size:13px">REG.NO.526/2005-06</p>
        <p style="margin:2px 0; font-size:12px">Regd.Office: "Mathrudhama" Gurupura-Kaikamba Kinnikambala Mangalore D.K.-574151 Ph: 9606912823</p>
      </td>
    </tr>
  </table>
  <p style="margin-top:10px;"><strong>Branch :</strong> <%= Current.branch.try(:name) %></p>
</div>

