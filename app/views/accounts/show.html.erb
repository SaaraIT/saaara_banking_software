
<% def calc_duration(from, to)
  return "" unless from.present? && to.present?
  from_date = from.is_a?(Date) ? from : Date.parse(from.to_s) rescue nil
  to_date   = to.is_a?(Date)   ? to   : Date.parse(to.to_s)   rescue nil
  return "" unless from_date && to_date && to_date > from_date
  years  = to_date.year  - from_date.year
  months = to_date.month - from_date.month
  days   = to_date.day   - from_date.day
  if days < 0
    months -= 1
    days += Date.new(to_date.year, to_date.month, 1).prev_day.day
  end
  if months < 0
    years  -= 1
    months += 12
  end
  parts = []
  parts << "#{years} #{"Year".pluralize(years)}"   if years  > 0
  parts << "#{months} #{"Month".pluralize(months)}" if months > 0
  parts << "#{days} #{"Day".pluralize(days)}"       if days   > 0
  parts.any? ? "( #{parts.join(" ")} )" : ""
end %>
